# Target Application (Juice Shop only — backend rejects other targets in later issues)
TARGET_APPLICATION_URL=http://juice-shop:3000

# OWASP ZAP API (daemon mode in Docker Compose)
ZAP_API_URL=http://zap:8080
ZAP_API_KEY=changeme

# Review state persistence
DATABASE_URL=sqlite:///./data/review.db

# LLM provider: mock (no API key) or nvidia
LLM_PROVIDER=mock

# NVIDIA NIM — optional; leave unset to use mock Agent Reasoning
# NVIDIA_API_KEY=
